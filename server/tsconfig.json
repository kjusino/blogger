{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "types": ["node", "express", "cookie-parser", "bcryptjs"],
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["**/*.ts"]
}
