# Copy to .env.local for local dev. In production these are set as Azure
# App Service Application Settings (Configuration → Application settings).

# bcrypt hash of your "side" password.
# Generate locally:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" "yourpassword"
SIDE_PASSWORD_HASH=

# Random 32+ byte hex string used to sign the session cookie.
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Port the Express server listens on. Only needed for local non-Docker dev
# (when running CRA on :3000 + Express on :3001 via `npm run dev`).
# Leave unset for Docker (Dockerfile sets PORT=3000) and Azure (sets PORT itself).
# PORT=3001
